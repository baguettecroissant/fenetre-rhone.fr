---
import config from '../data/config.json';
import '../styles/global.css';
import communes from '../data/communes.json';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
}

const { 
  title = `${config.brandName} | Changement de Fenêtres Rhône (69) — Artisans RGE 2026`, 
  description = config.description,
  canonicalUrl,
  robots = 'index, follow'
} = Astro.props;

const siteUrl = `https://${config.domain}`;

// Auto-generate canonical URL from current page if not explicitly passed
let resolvedPathname = Astro.url.pathname;
if (!resolvedPathname.endsWith('/')) {
  resolvedPathname += '/';
}
const resolvedCanonical = canonicalUrl || `${siteUrl}${resolvedPathname}`;

// Top 10 communes for footer popular list (already sorted by population)
const topFooterCommunes = communes.slice(0, 10);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
    <meta name="theme-color" content="#6B1D36" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="alternate" hreflang="fr" href={resolvedCanonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={config.brandName} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteUrl}/images/hero-fenetre-rhone.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/hero-fenetre-rhone.png`} />

    <!-- Geo meta tags for local SEO -->
    <meta name="geo.region" content="FR-69" />
    <meta name="geo.placename" content={config.mainCity} />

    <!-- Schema.org JSON-LD slot -->
    <slot name="head" />
  </head>
  <body>
    <!-- Header -->
    <header>
      <div class="container header-inner" style="width: 100%;">
        <a href="/" class="logo">
          <span>🪟</span> {config.brandName}
        </a>
        <nav class="header-nav" aria-label="Navigation principale">
          <a href="/">Accueil</a>
          <a href="/tarifs/">🧮 Tarifs</a>
          <a href="/aides-renovation-fenetre/">Aides Financières</a>
          <a href="/comparatif-materiaux/">Guide Matériaux</a>
          <a href="/communes/">Villes (69)</a>
        </nav>
        <div class="header-actions">
          <a href="/devis/" class="contact-btn">
            📋 Devis <span class="hide-mobile-text">Gratuit</span>
          </a>
          <button class="mobile-menu-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content Slot -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer>
      <div class="container footer-grid-enriched">
        <div class="footer-brand">
          <h3>🪟 {config.brandName}</h3>
          <p style="margin-top: 10px;">Votre portail de confiance pour comparer les installateurs et fabricants de fenêtres dans le Rhône ({config.departmentCode}). PVC, aluminium, bois ou mixte : trouvez des professionnels certifiés RGE. Obtenez 3 devis gratuits et estimez vos subventions nationales 2026.</p>
        </div>
        <div class="footer-links">
          <h4>Tarifs &amp; Guides</h4>
          <ul style="margin-top: 10px;">
            <li><a href="/tarifs/" style="font-weight: 600; color: var(--secondary);">🧮 Tarifs Menuiserie 2026</a></li>
            <li><a href="/aides-renovation-fenetre/">Aides Financières</a></li>
            <li><a href="/comparatif-materiaux/">Comparateur Matériaux</a></li>
            <li><a href="/guides/">Guides Rénovation</a></li>
            <li><a href="/communes/">Toutes les communes (69)</a></li>
            <li><a href="/devis/" style="font-weight: 600; color: var(--secondary);">📋 Demander mes devis</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Menuiserie RGE</h4>
          <ul style="margin-top: 10px;">
            <li><a href={`/remplacement-fenetre-${config.mainCity.toLowerCase()}/`}>Remplacement {config.mainCity}</a></li>
            <li><a href={`/fenetre-alu-${config.mainCity.toLowerCase()}/`}>Fenêtre Alu {config.mainCity}</a></li>
            <li><a href={`/artisan-menuisier-${config.mainCity.toLowerCase()}/`}>Artisan RGE {config.mainCity}</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Villes populaires (69)</h4>
          <ul style="margin-top: 10px;">
            {topFooterCommunes.map((c) => (
              <li>
                <a href={`/remplacement-fenetre-${c.slug}/`}>{c.nom}</a>
                <span style="font-size: 10px; color: #fdba74; margin-left: 4px;">
                  (<a href={`/fenetre-alu-${c.slug}/`} style="color: #fca5a5; text-decoration: none;" title={`Fenêtre Alu ${c.nom}`}>alu</a> · <a href={`/artisan-menuisier-${c.slug}/`} style="color: #fca5a5; text-decoration: none;" title={`Artisan RGE ${c.nom}`}>artisan</a>)
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} {config.brandName}. Tous droits réservés.</p>
        <p>
          <a href="/mentions-legales/">Mentions Légales</a> | 
          <a href="/politique-confidentialite/">Confidentialité (RGPD)</a>
        </p>
      </div>
    </footer>

    <!-- Exit Intent Popup -->
    <ExitIntentPopup />

    <script>
      // Mobile menu toggle
      const menuToggle = document.querySelector('.mobile-menu-toggle');
      const headerNav = document.querySelector('.header-nav');
      
      if (menuToggle && headerNav) {
        menuToggle.addEventListener('click', () => {
          const isActive = menuToggle.classList.toggle('active');
          headerNav.classList.toggle('active');
          menuToggle.setAttribute('aria-expanded', String(isActive));
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (!menuToggle.contains(target) && !headerNav.contains(target)) {
            menuToggle.classList.remove('active');
            headerNav.classList.remove('active');
            menuToggle.setAttribute('aria-expanded', 'false');
          }
        });

        headerNav.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            menuToggle.classList.remove('active');
            headerNav.classList.remove('active');
            menuToggle.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // Smooth scroll to devis form if present, else navigate standardly
      document.querySelectorAll('a[href="/devis/"], a[href="#devis"], .contact-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const targetForm = document.getElementById('devis');
          if (targetForm) {
            e.preventDefault();
            targetForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
            targetForm.classList.add('pulse-form');
            setTimeout(() => {
              targetForm.classList.remove('pulse-form');
            }, 3000);

            const firstBox = targetForm.querySelector('.option-box') as HTMLElement;
            if (firstBox) {
              firstBox.focus();
              firstBox.style.outline = '3px solid var(--secondary)';
              setTimeout(() => {
                if (firstBox) firstBox.style.outline = '';
              }, 3000);
            }
          }
        });
      });
    </script>
  </body>
</html>
