---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import config from '../data/config.json';

const title = `Demande Envoyée avec Succès | ${config.brandName}`;
const description = `Votre demande d'estimation ou de devis de fenêtre a bien été reçue. Des menuisiers RGE du Rhône vous contacteront rapidement.`;
---

<Layout title={title} description={description} robots="noindex, nofollow">
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
  />

  <div class="container" style="max-width: 650px; padding-top: 60px; padding-bottom: 90px; text-align: center;">
    <div style="background-color: var(--card-bg); border: 2px solid var(--border-color); border-radius: var(--radius-md); padding: 50px 30px; box-shadow: var(--shadow-md);">
      <div style="font-size: 64px; margin-bottom: 20px;">🎉</div>
      <h1 style="font-size: 30px; color: var(--primary); font-family: var(--font-heading); font-weight: 800; margin-bottom: 15px;">Merci ! Votre demande a bien été enregistrée</h1>
      <p style="font-size: 16px; color: var(--text); line-height: 1.6; margin-bottom: 30px;">
        Votre projet a été transmis avec succès à nos menuisiers partenaires qualifiés RGE du Rhône (69). Vous recevrez par e-mail ou téléphone jusqu'à <strong>3 devis gratuits sous 48 heures</strong>.
      </p>

      <!-- Steps status indicator -->
      <div style="display: flex; justify-content: center; gap: 20px; margin-bottom: 35px; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--success); font-weight: 600;">
          <span style="background-color: #d1fae5; width: 20px; height: 20px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 10px;">✓</span> Qualifié
        </div>
        <div style="display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--success); font-weight: 600;">
          <span style="background-color: #d1fae5; width: 20px; height: 20px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 10px;">✓</span> Transmis aux artisans
        </div>
        <div style="display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--secondary); font-weight: 600;">
          <span style="background-color: var(--primary-light); width: 20px; height: 20px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; border: 1px dashed var(--secondary);">⏳</span> Chiffrage en cours
        </div>
      </div>

      <div style="border-top: 1.5px solid var(--primary-light); padding-top: 25px;">
        <h3 style="font-size: 15px; color: var(--primary); font-weight: bold; margin-bottom: 15px;">En attendant, consultez nos guides pratiques :</h3>
        <div style="display: flex; flex-direction: column; gap: 10px; text-align: left;">
          <a href="/guides/budget-remplacement-fenetre-lyon-2026/" style="font-size: 14px; color: var(--secondary); text-decoration: none;">
            💡 Quel budget pour changer vos fenêtres dans le Rhône ? Notre guide complet &rarr;
          </a>
          <a href="/guides/aides-financieres-eco-ptz-maprimerenov/" style="font-size: 14px; color: var(--secondary); text-decoration: none;">
            💰 Comment cumuler MaPrimeRénov' et CEE ? &rarr;
          </a>
          <a href="/guides/pvc-vs-aluminium-quel-materiau-choisir/" style="font-size: 14px; color: var(--secondary); text-decoration: none;">
            🪟 PVC, Aluminium ou Bois : quel matériau privilégier ? &rarr;
          </a>
        </div>
      </div>
    </div>

    <div style="margin-top: 30px;">
      <a href="/" style="font-weight: 700; font-size: 15px; color: var(--primary); text-decoration: none;">
        &larr; Retour à l'accueil
      </a>
    </div>
  </div>
</Layout>
